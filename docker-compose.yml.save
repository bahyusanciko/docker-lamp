version: "3.1"
services:
    www:
        build: .
        ports: 
            - "80:80"
        volumes:
            - ./www:/var/www/html/
        links:
            - db
        networks:
            - default
    dbmysql:
        image: mysql
        ports: 
            - "3306:3306"
        command: --default-authentication-plugin=mysql_native_password
        environment:
            MYSQL_DATABASE: mydb
            MYSQL_USER: itsaba
            MYSQL_PASSWORD: itsaba
            MYSQL_ROOT_PASSWORD: sabait2005 
        volumes:
            - ./dump:/docker-entrypoint-initdb.d
            - ./conf:/etc/mysql/conf.d
            - persistent:/var/lib/mysql
        networks:
            - default
    db:
	image: postgres
	container_name: "postgres"
	ports:
	- "5432:5432"
	volumes:
	- dbpostgres:/var/lib/postgresql/data
	volumes:
	  dbpostreges:y

volumes:
    persistent:
